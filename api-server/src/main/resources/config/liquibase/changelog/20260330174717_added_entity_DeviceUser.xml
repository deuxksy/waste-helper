<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260330174717-1" author="waste-helper">
        <createTable tableName="device_users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="device_id" type="varchar(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints foreignKeyName="fk_device_users_user_id" referencedTableName="jhi_user" referencedColumnNames="id"/>
            </column>
            <column name="fingerprint_hash" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="20260330174717-2" author="waste-helper">
        <createIndex tableName="device_users" indexName="idx_device_users_device_id">
            <column name="device_id"/>
        </createIndex>
        <createIndex tableName="device_users" indexName="idx_device_users_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="20260330174717-3" author="waste-helper">
        <addColumn tableName="waste_classification">
            <column name="device_id" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260330174717-4" author="waste-helper">
        <createIndex tableName="waste_classification" indexName="idx_waste_classification_device_id">
            <column name="device_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="20260330174717-5" author="waste-helper">
        <addColumn tableName="search_history">
            <column name="device_id" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260330174717-6" author="waste-helper">
        <createIndex tableName="search_history" indexName="idx_search_history_device_id">
            <column name="device_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>